# =============================================================================
# CultivLab Platform — Environment Variables
# =============================================================================
# Copy this file to .env and fill in your values.
#
#   cp .env.example .env
#
# REQUIRED = must be set before running anything
# OPTIONAL = has a sensible default; override as needed
#
# NEVER commit .env to git. The pre-commit hook will catch it.
# =============================================================================


# -----------------------------------------------------------------------------
# DOMAIN & IDENTITY  (Sprint 1)
# -----------------------------------------------------------------------------

# REQUIRED — Your operator domain. All subdomains derive from this.
# Example: example.com → chat.example.com, api.example.com, etc.
DOMAIN=example.com

# REQUIRED — Founder / operator admin email address.
FOUNDER_ADMIN_EMAIL=admin@example.com

# REQUIRED — IP address(es) allowed to access admin and founder subdomains.
# Comma-separated CIDR notation. Use your home/office static IP.
# Example: 1.2.3.4/32 or 1.2.3.4/32,5.6.7.8/32
FOUNDER_ALLOWED_IP=0.0.0.0/32


# -----------------------------------------------------------------------------
# GCP  (Sprint 1)
# -----------------------------------------------------------------------------

# REQUIRED — GCP project ID. Create this before running any infra scripts.
GCP_PROJECT_ID=your-gcp-project-id

# OPTIONAL — GCP region for VM and other resources.
GCP_REGION=us-central1

# OPTIONAL — GCP zone for the VM.
GCP_ZONE=us-central1-a

# OPTIONAL — Compute Engine VM name.
VM_NAME=cultivlab-vm

# OPTIONAL — VM machine type. e2-small covers the MVP stack comfortably.
VM_MACHINE_TYPE=e2-small

# OPTIONAL — VM boot disk size in GB.
VM_DISK_SIZE_GB=20

# OPTIONAL — Name for the static external IP resource.
STATIC_IP_NAME=cultivlab-vm-ip

# OPTIONAL — GCP service account email for the VM (created by bootstrap script).
VM_SERVICE_ACCOUNT_EMAIL=cultivlab-vm@${GCP_PROJECT_ID}.iam.gserviceaccount.com


# -----------------------------------------------------------------------------
# LLM PROVIDER KEYS  (Sprint 2)
# -----------------------------------------------------------------------------

# REQUIRED — Anthropic API key for Claude models.
ANTHROPIC_API_KEY=sk-ant-placeholder

# REQUIRED — OpenAI API key for GPT models.
OPENAI_API_KEY=sk-placeholder

# OPTIONAL — Vertex AI project ID (defaults to GCP_PROJECT_ID).
# Required only if Vertex AI project differs from main GCP project.
VERTEX_AI_PROJECT=${GCP_PROJECT_ID}

# OPTIONAL — Vertex AI location for Gemini models.
VERTEX_AI_LOCATION=us-central1

# OPTIONAL — Path to Vertex AI service account key file on the VM.
# Leave blank to use Application Default Credentials (recommended).
VERTEX_AI_SERVICE_ACCOUNT_KEY_PATH=


# -----------------------------------------------------------------------------
# LITELLM  (Sprint 2)
# -----------------------------------------------------------------------------

# REQUIRED — LiteLLM master key. Generate with: openssl rand -hex 32
# This key controls the entire LiteLLM proxy. Guard it carefully.
LITELLM_MASTER_KEY=sk-placeholder-generate-with-openssl

# REQUIRED — LiteLLM salt key for hashing virtual keys in the database.
# Generate with: openssl rand -hex 32  (different value from LITELLM_MASTER_KEY)
LITELLM_SALT_KEY=placeholder-generate-with-openssl

# REQUIRED — LiteLLM admin UI login credentials (separate from master key).
# UI_USERNAME can be anything; UI_PASSWORD must be set to access admin.${DOMAIN}/ui
# Generate password with: openssl rand -base64 24 | tr -d '/+=' | head -c 32
UI_USERNAME=admin
UI_PASSWORD=placeholder-generate-with-openssl

# OPTIONAL — Pinned LiteLLM Docker image version.
LITELLM_VERSION=1.57.3

# OPTIONAL — Comma-separated list of model names exposed to students.
# Must match model names in infra/litellm/config.yaml
LITELLM_ALLOWED_MODELS=claude-sonnet-4-6,gpt-4o-mini,gemini-2.5-flash

# OPTIONAL — Whether LiteLLM enforces the user field on every request.
# Set to true so per-student attribution works in the admin UI.
LITELLM_ENFORCE_USER_PARAM=true

# OPTIONAL — Base URL the operator's scripts use to reach the LiteLLM admin API.
# Leave empty to default to https://api.${DOMAIN}. Override only if running
# admin scripts from inside the VM (use http://litellm:4000) — uncommon.
LITELLM_ADMIN_URL=


# -----------------------------------------------------------------------------
# POSTGRES  (Sprint 1)
# -----------------------------------------------------------------------------

# REQUIRED — Postgres superuser password. Generate with: openssl rand -hex 24
POSTGRES_PASSWORD=placeholder-generate-with-openssl

# OPTIONAL — Postgres database name (shared by LiteLLM and Open WebUI).
POSTGRES_DB=cultivlab

# OPTIONAL — Postgres user.
POSTGRES_USER=cultivlab

# OPTIONAL — Constructed automatically from the above. Override only if needed.
DATABASE_URL=postgresql://${POSTGRES_USER}:${POSTGRES_PASSWORD}@postgres:5432/${POSTGRES_DB}

# OPTIONAL — Pinned Postgres Docker image version (with pgvector from Sprint 2+).
POSTGRES_VERSION=16-alpine


# -----------------------------------------------------------------------------
# CADDY  (Sprint 1)
# -----------------------------------------------------------------------------

# OPTIONAL — Pinned Caddy Docker image version.
CADDY_VERSION=2.8.4-alpine


# -----------------------------------------------------------------------------
# OPEN WEBUI  (Sprint 3)
# -----------------------------------------------------------------------------

# REQUIRED — Pinned Open WebUI Docker image version.
OPENWEBUI_VERSION=0.5.20

# REQUIRED — Session encryption key for Open WebUI. Generate with: openssl rand -base64 32
# Used for signing session cookies. Rotating it invalidates all active sessions.
OPENWEBUI_SECRET_KEY=placeholder-generate-with-openssl

# OPTIONAL — Platform name shown in the Open WebUI login page and browser tab.
# Default: CultivLab. Change to your cohort program name if desired.
WEBUI_NAME=CultivLab

# REQUIRED — Whether the Open WebUI signup form is enabled.
# Set to false in production once cohort accounts are provisioned (via provision-students.sh).
# Set to true temporarily during initial admin account creation, then disable.
OPENWEBUI_ENABLE_SIGNUP=true

# REQUIRED — Default role assigned to newly-created Open WebUI accounts.
# Options: user (chat-only, no admin), admin (full access). Keep as user for student accounts.
OPENWEBUI_DEFAULT_USER_ROLE=user

# REQUIRED — System prompt injected for student chat sessions (via Open WebUI per-model config).
# Keep this kid-appropriate. Sprint 3 wires this into Open WebUI defaults; per-cohort overrides
# can be set via Open WebUI admin panel.
KID_MODE_SYSTEM_PROMPT="You are a helpful tutor for students aged 8 to 12. Use simple, friendly language. Encourage curiosity and creativity. Never produce inappropriate content."


# -----------------------------------------------------------------------------
# SLACK ALERTING  (Sprint 2)
# All five webhooks are REQUIRED during cohort operations.
# Create separate Slack channels and incoming webhooks for each.
# -----------------------------------------------------------------------------

# REQUIRED — Budget alerts (80% threshold, student blocked, cohort cap).
SLACK_WEBHOOK_BUDGET=https://hooks.slack.com/services/placeholder/budget

# REQUIRED — Daily and weekly spend reports.
SLACK_WEBHOOK_REPORTS=https://hooks.slack.com/services/placeholder/reports

# REQUIRED — LLM provider errors and exceptions.
SLACK_WEBHOOK_EXCEPTIONS=https://hooks.slack.com/services/placeholder/exceptions

# REQUIRED — Moderation triggers and safety events.
SLACK_WEBHOOK_SAFETY=https://hooks.slack.com/services/placeholder/safety

# REQUIRED — Platform health: VM disk, Postgres, SSL cert expiry.
SLACK_WEBHOOK_PLATFORM=https://hooks.slack.com/services/placeholder/platform


# -----------------------------------------------------------------------------
# COHORT CONFIGURATION  (Sprint 3)
# -----------------------------------------------------------------------------

# OPTIONAL — Human-readable cohort name (used in keys, reports, onboarding cards).
COHORT_NAME=cohort-2026-spring

# OPTIONAL — Cohort start and end dates (YYYY-MM-DD).
COHORT_START=2026-01-01
COHORT_END=2026-01-22

# OPTIONAL — Number of students in the cohort.
COHORT_SIZE=12

# OPTIONAL — Path to students.csv on the operator's machine (NEVER commit this file).
# Format: name,email,slug,parent_email
STUDENTS_CSV_PATH=/path/to/students.csv

# OPTIONAL — Budget cap for the entire cohort across all students.
# This is the outer wall — even if every student maxes out individually, the
# cohort cap prevents spending beyond this amount.
COHORT_MAX_BUDGET=200.00

# OPTIONAL — Soft budget for the cohort (alerts fire at this threshold).
COHORT_SOFT_BUDGET=150.00


# -----------------------------------------------------------------------------
# PER-STUDENT BUDGET DEFAULTS  (Sprint 3)
# These are defaults applied to all students. Per-student overrides go in
# students.csv as additional columns.
# -----------------------------------------------------------------------------

# OPTIONAL — Hard budget cap per student over the full cohort duration.
STUDENT_MAX_BUDGET=10.00

# OPTIONAL — Soft budget per student (Slack alert fires when exceeded).
STUDENT_SOFT_BUDGET=8.00

# OPTIONAL — Hard daily budget cap per student (resets at midnight UTC).
STUDENT_DAILY_BUDGET=2.00

# OPTIONAL — Hard weekly budget cap per student.
STUDENT_WEEKLY_BUDGET=8.00

# OPTIONAL — Requests per minute limit per student virtual key.
STUDENT_RPM_LIMIT=60

# OPTIONAL — Tokens per minute limit per student virtual key.
STUDENT_TPM_LIMIT=50000


# -----------------------------------------------------------------------------
# FIREBASE  (Sprint 4)
# Used for student static site hosting at <slug>.${DOMAIN}
# -----------------------------------------------------------------------------

# REQUIRED (Sprint 4) — Firebase project ID for student site hosting.
FIREBASE_PROJECT_ID=your-firebase-project-id

# OPTIONAL — Path to Firebase service account key JSON on the VM.
# Leave blank to use Application Default Credentials.
FIREBASE_SERVICE_ACCOUNT_KEY_PATH=


# -----------------------------------------------------------------------------
# FOUNDER CONSOLE  (Sprint 5.5)
# -----------------------------------------------------------------------------

# REQUIRED (Sprint 5.5) — bcrypt hash of the founder console password.
# Generate with: python3 -c "import bcrypt; print(bcrypt.hashpw(b'your-password', bcrypt.gensalt()).decode())"
FOUNDER_CONSOLE_PASSWORD_HASH=placeholder-bcrypt-hash

# REQUIRED (Sprint 5.5) — Secret key for itsdangerous cookie signing.
# Generate with: openssl rand -hex 32
FOUNDER_CONSOLE_SECRET_KEY=placeholder-generate-with-openssl

# OPTIONAL — Pinned Founder Console Docker image version (internal service).
FOUNDER_CONSOLE_VERSION=latest


# -----------------------------------------------------------------------------
# LANGFUSE  (Sprint 4 / Iteration 4)
# Observability, tracing, and evals. Not used until Sprint 4.
# -----------------------------------------------------------------------------

# OPTIONAL — Pinned Langfuse Docker image version.
LANGFUSE_VERSION=2.71.0

# REQUIRED (Sprint 4) — Langfuse secret key. Generate with: openssl rand -hex 32
LANGFUSE_SECRET_KEY=placeholder-generate-with-openssl

# REQUIRED (Sprint 4) — Langfuse public key. Generate with: openssl rand -hex 16
LANGFUSE_PUBLIC_KEY=placeholder-generate-with-openssl

# OPTIONAL — Langfuse host (default: internal Docker network service name).
LANGFUSE_HOST=http://langfuse:3000


# -----------------------------------------------------------------------------
# MONITORING  (Sprint 5)
# -----------------------------------------------------------------------------

# OPTIONAL — Webhook URL for external uptime monitor (e.g. UptimeRobot, Better Stack).
# Leave blank to skip external uptime monitoring.
UPTIME_MONITOR_WEBHOOK=

# OPTIONAL — GCP billing budget alert threshold in USD.
GCP_BILLING_ALERT_USD=50


# -----------------------------------------------------------------------------
# EMAIL INTEGRATION  (Sprint 5 — soft budget parent alerts)
# OPTIONAL — only needed if you want soft-budget alerts emailed to parents.
# Supported providers: resend, sendgrid, smtp
# -----------------------------------------------------------------------------

# OPTIONAL
EMAIL_PROVIDER=resend

# OPTIONAL — API key for the email provider.
EMAIL_API_KEY=placeholder

# OPTIONAL — From address for all platform emails.
EMAIL_FROM=platform@example.com


# -----------------------------------------------------------------------------
# SPRINT 5 — CRON / OPERATIONAL SCRIPTS
# Scripts run directly on the VM; these names must match the Docker Compose
# service names (see infra/docker-compose.yml).
# -----------------------------------------------------------------------------

# OPTIONAL — Docker container name for Postgres (used by cron scripts on the VM).
# Must match the cultivlab Docker Compose project name + service name.
POSTGRES_CONTAINER=cultivlab-postgres-1

# OPTIONAL — Docker container name for LiteLLM (used by cron scripts on the VM).
LITELLM_CONTAINER=cultivlab-litellm-1

# OPTIONAL — Docker container name for Open WebUI (used by restore script to
# stop/start the service around a production database restore).
OPENWEBUI_CONTAINER=cultivlab-open-webui-1

# REQUIRED (Sprint 5) — GCS bucket name for daily Postgres backups.
# Create with: gsutil mb -p ${GCP_PROJECT_ID} -l us-central1 gs://your-bucket-name
# Recommended naming: ${GCP_PROJECT_ID}-cultivlab-backups
GCS_BACKUP_BUCKET=your-project-cultivlab-backups


# -----------------------------------------------------------------------------
# SAFETY MODERATION  (Sprint 3)
# -----------------------------------------------------------------------------

# OPTIONAL — When true, the safety moderation callback alerts Slack but does
# NOT block the request. Useful during initial tuning to identify false
# positives without rejecting legitimate kid-mode prompts.
SAFETY_LOG_ONLY=false

# OPTIONAL — Disable safety moderation entirely. Debug only; never set true
# in production.
SAFETY_MODERATION_DISABLED=false


# -----------------------------------------------------------------------------
# SPRINT 6 — Founder Console OW integration
# -----------------------------------------------------------------------------

# REQUIRED (Sprint 3 / Sprint 6) — Open WebUI admin account credentials.
# Used by provision-students.sh (Mac) and the Founder Console (VM) to call the
# OW admin API for account suspend/resume. These are the credentials for the
# first OW account created during initial setup.
OPENWEBUI_ADMIN_EMAIL=admin@example.com
OPENWEBUI_ADMIN_PASSWORD=placeholder-change-me

# REQUIRED (Sprint 6) — Internal Docker network URL for the Open WebUI service.
# Used by the Founder Console to call the OW admin API from inside the container.
# Do NOT use the public chat.${DOMAIN} URL here — this must be the internal name.
OPENWEBUI_URL=http://open-webui:8080
