# infra/Caddyfile.tmpl
# Rendered to infra/Caddyfile by scripts/bootstrap.sh via envsubst.
# DO NOT edit the rendered file (it is gitignored); edit this template.
#
# Five route patterns:
#   api.${DOMAIN}     — public LiteLLM API. Auto-HTTPS, HTTP→HTTPS redirect.
#   admin.${DOMAIN}   — LiteLLM admin UI. Auto-HTTPS. IP-locked. 403 from any
#                        address not in ${FOUNDER_ALLOWED_IP}.
#   chat.${DOMAIN}    — Open WebUI student chat surface. Auto-HTTPS, public.
#   founder.${DOMAIN} — Founder Console (FastAPI+HTMX). Auto-HTTPS. IP-locked.
#                        Same ${FOUNDER_ALLOWED_IP} allowlist as admin.
#   l##.${DOMAIN}     — Student site slots (Sprint 4). Static files from
#                        /srv/students/<slot>/. Auto-HTTPS, public. See ADR-013.
#
# Caddy v2 supports multiple CIDRs in `remote_ip` separated by spaces.
# bootstrap.sh normalizes commas in ${FOUNDER_ALLOWED_IP} to spaces before
# rendering, so both single and comma-separated env values work.

{
	email ${FOUNDER_ADMIN_EMAIL}
}

api.${DOMAIN} {
	encode zstd gzip
	reverse_proxy litellm:4000
}

admin.${DOMAIN} {
	encode zstd gzip

	@allowed remote_ip ${FOUNDER_ALLOWED_IP}
	handle @allowed {
		# Convenience: redirect bare-domain visitors to /ui.
		@root path /
		rewrite @root /ui
		reverse_proxy litellm:4000
	}
	handle {
		respond "Forbidden" 403
	}
}

chat.${DOMAIN} {
	encode zstd gzip
	reverse_proxy open-webui:8080
}

founder.${DOMAIN} {
	encode zstd gzip

	@allowed remote_ip ${FOUNDER_ALLOWED_IP}
	handle @allowed {
		reverse_proxy founder-console:8080
	}
	handle {
		respond "Forbidden" 403
	}
}

# Student site slots (Sprint 4) — slot-based subdomains for cohort use.
# See ADR-013 for the design (privacy: no student names in URLs).
# Caddy serves /srv/students/<slot>/ for each explicit slot. To add new slots:
#   1. Add DNS A record for lNN.${DOMAIN} -> VM IP at the registrar
#   2. Append lNN.${DOMAIN} to the comma-separated list below
#   3. Create /srv/students/lNN/ directory on VM
#   4. Re-run scripts/bootstrap.sh
l01.${DOMAIN}, l02.${DOMAIN}, l03.${DOMAIN}, l04.${DOMAIN}, l05.${DOMAIN}, l06.${DOMAIN} {
	encode zstd gzip

	# Student file upload endpoint — routed to Founder Console.
	# Caddy injects the slot name (e.g. "l01") so the app knows which
	# directory to write to without parsing the Host header itself.
	handle /upload* {
		header_up X-Student-Slot {labels.2}
		reverse_proxy founder-console:8080
	}

	# Everything else — static files from the slot directory.
	handle {
		root * /srv/students/{labels.2}
		file_server
	}
}
